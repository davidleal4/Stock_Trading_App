# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_trading

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Environment
ENVIRONMENT=development
DEBUG=true

# Security
SECRET_KEY=your-secret-key-change-in-production

# API Keys for Data Sources
EODHD_API_KEY=your_eodhd_api_key
POLYGON_API_KEY=your_polygon_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# Fidelity API (Sandbox by default)
FIDELITY_API_KEY=your_fidelity_api_key
FIDELITY_API_SECRET=your_fidelity_api_secret
FIDELITY_SANDBOX=true

# OpenAI API (Optional)
OPENAI_API_KEY=your_openai_api_key

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# ML Model Configuration
MODEL_STORAGE_PATH=./models